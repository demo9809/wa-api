# Server
PORT=3001

# Security — change this to a random 64-character string before deploying
API_SECRET_KEY=change_this_to_random_64_char_string

# Anti-ban limits
MAX_DAILY_MESSAGES=150
MIN_DELAY_MS=4000
MAX_DELAY_MS=10000

# Retry settings
MAX_RETRIES=3

# Typing simulation delay range (ms)
TYPING_MIN_MS=1000
TYPING_MAX_MS=3000

# Reconnection settings
RECONNECT_DELAY_MS=10000
MAX_RECONNECT_ATTEMPTS=10

# Logging
LOG_LEVEL=info

# Site URL (used in templates)
PHP_SITE_URL=https://illoo.store

# Environment
NODE_ENV=production
